    <worksheet name='Scatter Plot'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Identifying High-Growth Expansion Targets 
</run>
            <run fontsize='11' italic='true'>Each dot represents a U.S. State.</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (state_retail_total)' name='federated.0few3la1clej481ccq2tn1n2wso3' />
          </datasources>
          <datasource-dependencies datasource='federated.0few3la1clej481ccq2tn1n2wso3'>
            <column caption='National Avg Unemployment' datatype='real' name='[Calculation_5369792943484930]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_AVG(AVG([Unemployment Rate]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Category' datatype='string' name='[Calculation_5369792954220551]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([Unemployment Rate]) &lt; [Calculation_5369792943484930] AND AVG([Pivot Field Values]) &gt; WINDOW_AVG(AVG([Pivot Field Values])) THEN &quot;Low Unemployment + High Retail Growth&quot;&#10;ELSEIF AVG([Unemployment Rate]) &lt; [Calculation_5369792943484930] THEN &quot;Low Unemployment + Low Retail Growth&quot;&#10;ELSE &quot;High Unemployment dominates&quot;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column aggregation='Avg' caption='Retail Growth %' datatype='real' name='[Pivot Field Values]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column aggregation='Avg' datatype='real' datatype-customized='true' name='[Unemployment Rate]' role='measure' type='quantitative' />
            <column-instance column='[Pivot Field Values]' derivation='Avg' name='[avg:Pivot Field Values:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Unemployment Rate]' derivation='Avg' name='[avg:Unemployment Rate:qk]' pivot='key' type='quantitative' />
            <column-instance column='[State]' derivation='None' name='[none:State:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_5369792954220551]' derivation='User' name='[usr:Calculation_5369792954220551:nk:2]' pivot='key' type='nominal'>
              <table-calc ordering-field='[federated.0few3la1clej481ccq2tn1n2wso3].[State]' ordering-type='Field' />
              <table-calc field='[federated.0few3la1clej481ccq2tn1n2wso3].[Calculation_5369792943484930]' ordering-field='[federated.0few3la1clej481ccq2tn1n2wso3].[State]' ordering-type='Field' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0few3la1clej481ccq2tn1n2wso3].[Action (State)]'>
            <groupfilter function='level-members' level='[State]' user:ui-action-filter='[Action1_36753722419C4A0D8E589CCF82B5168E]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='quantitative' column='[federated.0few3la1clej481ccq2tn1n2wso3].[avg:Unemployment Rate:qk]' included-values='non-null' />
          <slices>
            <column>[federated.0few3la1clej481ccq2tn1n2wso3].[avg:Unemployment Rate:qk]</column>
