            <column caption='National Avg Unemployment' datatype='real' name='[Calculation_5369792943484930]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_AVG(AVG([Unemployment Rate]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Category' datatype='string' name='[Calculation_5369792954220551]' role='measure' type='nominal'>
